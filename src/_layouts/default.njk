{% include "header.njk" %}

<body class="bg-slate-200 dark:bg-slate-700 flex flex-col min-h-screen content-center">

  <div class="container p-2 mx-auto max-w-6xl">
    <div class="flex flex-row flex-wrap py-4">
      
      <aside class="w-full sm:w-1/3 md:w-1/4 px-2 pb-3">
        <div class="sticky top-0 p-4 rounded w-full shadow-md border-solid border-2 border-slate-300 bg-slate-100 dark:bg-slate-800">
          <div class="p-4 grid justify-end ">
            <img src="/assets/images/logo.svg" width="50" height="50">
          </div>

          <div class="">
            {% include "sidebar.njk" %}
          </div>
      </div>
    </aside>

    <main role="main" class="w-full sm:w-2/3 md:w-3/4 px-2 space-y-6">
{#- this is where the content goes -#}
      {{ content | safe}}
    </main>
  </div>
</div>

{%- include "footer.njk" -%}
</body>

